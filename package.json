  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/convert.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "docker:up": "docker compose --env-file .env.docker up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
